PORT=3000
NODE_ENV=development

# Supabase — app principal (proyectos, clientes, empresas)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Supabase — catálogo de prendas (proyecto separado)
SUPABASE_CATALOG_URL=
SUPABASE_CATALOG_SERVICE_ROLE_KEY=
SUPABASE_CATALOG_ANON_KEY=

# Demo — empresa fija para style-match (opcional; evita mandar empresaId en cada request)
DEMO_EMPRESA_ID=

# Cloudinary (required for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenAI / Codex (style extraction + garment classification)
# Prefer Codex credits — same OpenAI-compatible API:
CODEX_API_KEY=
CODEX_API_URL=https://api.openai.com/v1/chat/completions
CODEX_MODEL=gpt-4o-mini
# Fallback direct OpenAI key (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Firecrawl (catalog scraping — mock used when empty)
FIRECRAWL_API_KEY=

# External bridge services (optional — mocks used when empty)
LLM_API_URL=
LLM_API_KEY=
VISION_CORE_URL=
SHOOT_MODEL_URL=

# n8n webhook (optional — mock used when empty) para WhatsApp
N8N_WEBHOOK_URL=
